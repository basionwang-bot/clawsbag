# ===== 数据库（生产环境推荐使用阿里云 RDS MySQL） =====
DATABASE_URL="mysql://user:password@your-rds-host:3306/clawsbag"

# ===== JWT 密钥（务必更换为强随机字符串，可用: openssl rand -hex 32） =====
JWT_SECRET="这里填一个64位随机字符串"

# ===== 阿里云 AccessKey（短信 + OSS 共用） =====
ALIYUN_ACCESS_KEY_ID=你的AccessKeyId
ALIYUN_ACCESS_KEY_SECRET=你的AccessKeySecret

# ===== 阿里云短信服务 =====
ALIYUN_SMS_SIGN_NAME=ClawsBag
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxx

# ===== 阿里云 OSS =====
ALIYUN_OSS_REGION=oss-cn-hangzhou
ALIYUN_OSS_BUCKET=clawsbag

# ===== 站点配置 =====
NODE_ENV=production
PORT=3000
